# ── Core ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://eios:eios_dev@localhost:5432/eios_db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS (required in production — comma-separated origins, no trailing slash) ─
# ALLOWED_ORIGINS=https://app.eios.io,https://api.eios.io

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: anthropic | openai | groq
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile   # or claude-sonnet-4-6 / gpt-4o
LLM_MAX_TOKENS=4096

# API keys — set exactly one matching your LLM_PROVIDER
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...

# ── LLM Budget (0 = unlimited) ────────────────────────────────────────────────
# Per-org monthly token cap. Workflows are rejected mid-run when exceeded.
LLM_MONTHLY_TOKEN_BUDGET=0

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5   # fast CPU; use multilingual-e5-large for prod
EMBEDDING_DIM=384
EMBEDDING_CHUNK_SIZE=512
EMBEDDING_CHUNK_OVERLAP=50

# ── Document Ingestion ────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Rate Limiting (requests per minute per IP) ────────────────────────────────
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_LLM_PER_MINUTE=20

# ── Database Connection Pool ──────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── External Intelligence Sources ─────────────────────────────────────────────
# EU Financial Sanctions Files (FSF) API token.
# Register free at: https://webgate.ec.europa.eu/fsd/fsf/
# Without a token the request returns HTTP 403 — collection skips gracefully.
# EU_SANCTIONS_TOKEN=your-token-here
