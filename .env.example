# ─── EIOS Environment Configuration Template ──────────────────────────────────
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Development defaults are shown. Production values are marked [REQUIRED].
# ──────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
# Values: development | staging | production
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=eios
POSTGRES_PASSWORD=eios_dev          # [REQUIRED in production — use a strong password]
POSTGRES_DB=eios_db

# Used directly by the backend service
DATABASE_URL=postgresql+asyncpg://eios:eios_dev@localhost:5432/eios_db

# Connection pool tuning
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── Security ──────────────────────────────────────────────────────────────────
# [REQUIRED in production] Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-me-in-production

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# [REQUIRED in production] Comma-separated list of allowed frontend origins
# Example: https://app.eios.io,https://staging.eios.io
# Leave empty for development (wildcard allowed automatically)
ALLOWED_ORIGINS=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_LLM_PER_MINUTE=20

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Values: anthropic | openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096

# Provide exactly one of the following:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── LLM Budget Control ────────────────────────────────────────────────────────
# Maximum tokens per organisation per calendar month. 0 = unlimited.
# Recommended for pilot: 500000 (approx. 5–10 full due diligence workflows/org)
LLM_MONTHLY_TOKEN_BUDGET=0

# ── Embedding Model ───────────────────────────────────────────────────────────
# Pilot / CPU: BAAI/bge-small-en-v1.5 (384 dims, fast)
# Production / multilingual: intfloat/multilingual-e5-large (1024 dims)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_CHUNK_SIZE=512
EMBEDDING_CHUNK_OVERLAP=50

# ── Document Ingestion ────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────────────────────────────────────
# The URL the browser uses to reach the backend API.
# Development: http://localhost:8000
# Production: https://api.eios.io
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Deployment ────────────────────────────────────────────────────────────────
BACKEND_WORKERS=2
