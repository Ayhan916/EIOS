# EIOS — Local Development Environment
# Copy this file to .env and fill in the required values.
# NEVER commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Required for AI Copilot (M08)
SECRET_KEY=dev-secret-key-change-me-min32chars!!

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Database (matches docker-compose.yml) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://eios:eios_dev@localhost:5432/eios_db
DATABASE_READONLY_URL=                # optional read replica — leave empty for dev

# ── Redis (matches docker-compose.yml) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_BLACKLIST_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── S3 / MinIO (optional for dev — set S3_ENABLED=true to test uploads) ───────
S3_ENABLED=false
S3_BUCKET=eios-documents
S3_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000  # MinIO local endpoint
AWS_ACCESS_KEY_ID=minio               # MinIO root user (docker-compose.yml)
AWS_SECRET_ACCESS_KEY=minio_dev       # MinIO root password (docker-compose.yml)
S3_PRESIGNED_URL_EXPIRE_SECONDS=3600

# ── Auth & Tokens ─────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_SESSION_EXPIRE_MINUTES=5
EXTERNAL_AUDIT_TOKEN_EXPIRE_HOURS=72

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096
LLM_MONTHLY_TOKEN_BUDGET=0            # 0 = unlimited
# OPENAI_API_KEY=sk-...              # only needed if LLM_PROVIDER=openai
# GROQ_API_KEY=gsk_...               # only needed if LLM_PROVIDER=groq

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_CHUNK_SIZE=512
EMBEDDING_CHUNK_OVERLAP=50

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_LLM_PER_MINUTE=20

# ── CORS (leave empty in dev — all origins allowed) ───────────────────────────
# ALLOWED_ORIGINS=https://app.eios.io,https://supplier.eios.io

# ── Document Upload ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Webhooks ──────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEBHOOK_SECRET_KEY=

# ── SMTP / Email (leave SMTP_HOST empty to disable email sending) ─────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@eios.io
SMTP_TLS=true
APP_BASE_URL=http://localhost:3000

# ── Database Connection Pool ──────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Multi-Region Data Residency (dev: not enforced) ───────────────────────────
INSTANCE_REGION=EU
REGION_ENFORCEMENT_STRICT=false
# REGION_DB_EU_URL=
# REGION_DB_US_URL=
# REGION_DB_APAC_URL=
# REGION_S3_BUCKET_EU=
# REGION_S3_BUCKET_US=
# REGION_S3_BUCKET_APAC=
