# EIOS — Production Environment
# Copy to .env.prod and fill in ALL values before first deploy.
# NEVER commit .env.prod to git.
#
# Usage with docker-compose.prod.yml:
#   cp .env.prod.example .env.prod
#   # Fill in all values below
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Use strong random values: openssl rand -base64 32
POSTGRES_USER=eios_prod
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=eios_prod

# ── Redis ──────────────────────────────────────────────────────────────────────
# Two separate Redis instances: rate-limit (allkeys-lru) + JWT blacklist (noeviction)
# openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_BLACKLIST_PASSWORD=CHANGE_ME_redis_blacklist_password

# ── Application ────────────────────────────────────────────────────────────────
# MUST be at least 32 chars: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_min_64_char_secret_key_generate_with_secrets_token_hex_32
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096
LLM_MONTHLY_TOKEN_BUDGET=0
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
# OPENAI_API_KEY=sk-CHANGE_ME         # only if LLM_PROVIDER=openai
# GROQ_API_KEY=gsk_CHANGE_ME          # only if LLM_PROVIDER=groq

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
EMBEDDING_CHUNK_SIZE=512
EMBEDDING_CHUNK_OVERLAP=50

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://app.eios.io,https://supplier.eios.io

# ── Frontend ───────────────────────────────────────────────────────────────────
# The browser-side API URL — must be the public HTTPS URL
NEXT_PUBLIC_API_URL=https://app.eios.io

# ── S3 / Object Storage ────────────────────────────────────────────────────────
S3_ENABLED=true
S3_BUCKET=eios-documents-prod
S3_REGION=eu-central-1
# S3_ENDPOINT_URL=                    # leave empty for AWS S3; set for MinIO/R2
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_PRESIGNED_URL_EXPIRE_SECONDS=3600

# ── Backup S3 Bucket (separate from documents) ─────────────────────────────────
S3_BACKUP_BUCKET=eios-backups-prod

# ── SMTP / Email ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.eu.mailgun.org
SMTP_PORT=587
SMTP_USER=noreply@eios.io
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@eios.io
SMTP_TLS=true
APP_BASE_URL=https://app.eios.io

# ── Webhooks ───────────────────────────────────────────────────────────────────
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEBHOOK_SECRET_KEY=CHANGE_ME

# ── Token Expiry ───────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_SESSION_EXPIRE_MINUTES=5
EXTERNAL_AUDIT_TOKEN_EXPIRE_HOURS=72

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_LLM_PER_MINUTE=20

# ── Database Connection Pool ───────────────────────────────────────────────────
DB_POOL_SIZE=20
DB_POOL_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── Backend Workers ────────────────────────────────────────────────────────────
# Adjust to 2× CPU cores of the host
BACKEND_WORKERS=4

# ── Domain / SSL ───────────────────────────────────────────────────────────────
# Used by Nginx and Let's Encrypt (Certbot)
DOMAIN=app.eios.io

# ── Multi-Region Data Residency ────────────────────────────────────────────────
INSTANCE_REGION=EU
REGION_ENFORCEMENT_STRICT=true
# REGION_DB_EU_URL=postgresql+asyncpg://...
# REGION_DB_US_URL=postgresql+asyncpg://...
# REGION_DB_APAC_URL=postgresql+asyncpg://...
# REGION_S3_BUCKET_EU=eios-eu-prod
# REGION_S3_BUCKET_US=eios-us-prod
# REGION_S3_BUCKET_APAC=eios-apac-prod

# ── Alerting (required for Alertmanager) ──────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME
PAGERDUTY_SERVICE_KEY=CHANGE_ME
